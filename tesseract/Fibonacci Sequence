def fibonacci(n: int) -> list:
    """Returns first n Fibonacci numbers"""
    seq = [0, 1]
    for _ in range(2, n):
        seq.append(seq[-1] + seq[-2])
    return seq

def fibonacci_harmony(current_step: int) -> float:
    """Returns harmony score based on Fibonacci position"""
    fib = fibonacci(20)  # up to 6765
    if current_step >= len(fib):
        return 100.0
    return round((current_step / len(fib)) * 100, 2)
